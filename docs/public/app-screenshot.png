<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 675" fill="none">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f8fafc"/>
      <stop offset="100%" style="stop-color:#e2e8f0"/>
    </linearGradient>
    <linearGradient id="brandGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6"/>
      <stop offset="50%" style="stop-color:#8b5cf6"/>
      <stop offset="100%" style="stop-color:#ec4899"/>
    </linearGradient>
    <linearGradient id="cardGrad" x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#ffffff"/>
      <stop offset="100%" style="stop-color:#f8fafc"/>
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="#64748b" flood-opacity="0.15"/>
    </filter>
    <filter id="glow" x="-50%" y="-50%" width="200%" height="200%">
      <feGaussianBlur stdDeviation="20" result="blur"/>
      <feMerge>
        <feMergeNode in="blur"/>
        <feMergeNode in="SourceGraphic"/>
      </feMerge>
    </filter>
  </defs>

  <!-- Background -->
  <rect width="1200" height="675" fill="url(#bgGrad)"/>

  <!-- Decorative circles -->
  <circle cx="100" cy="100" r="200" fill="#3b82f6" opacity="0.05"/>
  <circle cx="1100" cy="575" r="250" fill="#8b5cf6" opacity="0.05"/>
  <circle cx="600" cy="337" r="400" fill="#ec4899" opacity="0.03"/>

  <!-- Main App Window -->
  <g filter="url(#shadow)">
    <rect x="150" y="80" width="900" height="515" rx="16" fill="url(#cardGrad)"/>
    <rect x="150" y="80" width="900" height="48" rx="16" fill="#f1f5f9"/>
    <rect x="150" y="112" width="900" height="16" fill="#f1f5f9"/>
  </g>

  <!-- Window controls -->
  <circle cx="178" cy="104" r="6" fill="#ef4444"/>
  <circle cx="198" cy="104" r="6" fill="#f59e0b"/>
  <circle cx="218" cy="104" r="6" fill="#22c55e"/>

  <!-- Sidebar -->
  <rect x="150" y="128" width="220" height="467" fill="#f8fafc"/>
  <line x1="370" y1="128" x2="370" y2="595" stroke="#e2e8f0" stroke-width="1"/>

  <!-- Sidebar items -->
  <rect x="166" y="148" width="188" height="36" rx="8" fill="#3b82f6" opacity="0.1"/>
  <text x="182" y="172" font-family="Inter, sans-serif" font-size="14" fill="#3b82f6" font-weight="500">📝 我的笔记</text>

  <text x="182" y="220" font-family="Inter, sans-serif" font-size="14" fill="#64748b">📁 工作</text>
  <text x="182" y="260" font-family="Inter, sans-serif" font-size="14" fill="#64748b">📁 生活</text>
  <text x="182" y="300" font-family="Inter, sans-serif" font-size="14" fill="#64748b">📁 学习</text>

  <!-- Sync status indicator -->
  <circle cx="178" cy="550" r="8" fill="#22c55e"/>
  <text x="196" y="555" font-family="Inter, sans-serif" font-size="12" fill="#64748b">已同步</text>

  <!-- Note list -->
  <rect x="370" y="128" width="240" height="467" fill="#ffffff"/>
  <line x1="610" y1="128" x2="610" y2="595" stroke="#e2e8f0" stroke-width="1"/>

  <text x="390" y="160" font-family="Inter, sans-serif" font-size="16" fill="#1e293b" font-weight="600">笔记列表</text>

  <!-- Note items -->
  <rect x="386" y="180" width="208" height="60" rx="8" fill="#f8fafc"/>
  <text x="402" y="205" font-family="Inter, sans-serif" font-size="14" fill="#1e293b" font-weight="500">项目计划</text>
  <text x="402" y="225" font-family="Inter, sans-serif" font-size="12" fill="#94a3b8">今天 14:30</text>

  <rect x="386" y="250" width="208" height="60" rx="8" fill="#3b82f6" opacity="0.08"/>
  <text x="402" y="275" font-family="Inter, sans-serif" font-size="14" fill="#1e293b" font-weight="500">会议记录</text>
  <text x="402" y="295" font-family="Inter, sans-serif" font-size="12" fill="#94a3b8">今天 10:15</text>

  <rect x="386" y="320" width="208" height="60" rx="8" fill="#f8fafc"/>
  <text x="402" y="345" font-family="Inter, sans-serif" font-size="14" fill="#1e293b" font-weight="500">学习笔记</text>
  <text x="402" y="365" font-family="Inter, sans-serif" font-size="12" fill="#94a3b8">昨天 20:45</text>

  <!-- Editor area -->
  <rect x="610" y="128" width="440" height="467" fill="#ffffff"/>

  <!-- Editor header -->
  <text x="630" y="160" font-family="Inter, sans-serif" font-size="18" fill="#1e293b" font-weight="600">会议记录</text>

  <!-- Editor toolbar -->
  <g transform="translate(630, 180)">
    <rect x="0" y="0" width="30" height="30" rx="6" fill="#f1f5f9"/>
    <text x="10" y="20" font-family="Inter, sans-serif" font-size="14" fill="#64748b">B</text>
    <rect x="36" y="0" width="30" height="30" rx="6" fill="#f1f5f9"/>
    <text x="46" y="20" font-family="Inter, sans-serif" font-size="14" fill="#64748b">I</text>
    <rect x="72" y="0" width="30" height="30" rx="6" fill="#f1f5f9"/>
    <text x="82" y="20" font-family="Inter, sans-serif" font-size="14" fill="#64748b">U</text>
  </g>

  <!-- Editor content lines -->
  <rect x="630" y="230" width="380" height="4" rx="2" fill="#e2e8f0"/>
  <rect x="630" y="250" width="320" height="4" rx="2" fill="#e2e8f0"/>
  <rect x="630" y="270" width="360" height="4" rx="2" fill="#e2e8f0"/>
  <rect x="630" y="290" width="280" height="4" rx="2" fill="#e2e8f0"/>
  <rect x="630" y="320" width="380" height="4" rx="2" fill="#e2e8f0"/>
  <rect x="630" y="340" width="300" height="4" rx="2" fill="#e2e8f0"/>
  <rect x="630" y="360" width="340" height="4" rx="2" fill="#e2e8f0"/>
  <rect x="630" y="380" width="260" height="4" rx="2" fill="#e2e8f0"/>

  <!-- Code block -->
  <rect x="630" y="410" width="380" height="80" rx="8" fill="#1e293b"/>
  <text x="650" y="438" font-family="JetBrains Mono, monospace" font-size="12" fill="#22c55e">// 加密数据</text>
  <text x="650" y="458" font-family="JetBrains Mono, monospace" font-size="12" fill="#60a5fa">const</text>
  <text x="690" y="458" font-family="JetBrains Mono, monospace" font-size="12" fill="#f8fafc"> encrypted =</text>
  <text x="795" y="458" font-family="JetBrains Mono, monospace" font-size="12" fill="#f59e0b">encrypt</text>
  <text x="850" y="458" font-family="JetBrains Mono, monospace" font-size="12" fill="#f8fafc">(note);</text>
  <text x="650" y="478" font-family="JetBrains Mono, monospace" font-size="12" fill="#94a3b8">// 只有你能解密</text>

  <!-- Floating devices illustration -->
  <g transform="translate(900, 500)">
    <!-- Phone -->
    <rect x="0" y="0" width="60" height="100" rx="8" fill="#ffffff" filter="url(#shadow)"/>
    <rect x="5" y="10" width="50" height="75" rx="4" fill="#f8fafc"/>
    <circle cx="30" cy="92" r="4" fill="#e2e8f0"/>

    <!-- Sync arrows -->
    <path d="M70 50 L85 50" stroke="#22c55e" stroke-width="2" stroke-dasharray="4 2"/>
    <path d="M85 45 L95 50 L85 55" fill="#22c55e"/>

    <!-- Tablet -->
    <rect x="100" y="10" width="90" height="70" rx="8" fill="#ffffff" filter="url(#shadow)"/>
    <rect x="105" y="15" width="80" height="55" rx="4" fill="#f8fafc"/>
  </g>

  <!-- Encryption badge -->
  <g transform="translate(165, 460)">
    <rect x="0" y="0" width="180" height="50" rx="10" fill="#ffffff" filter="url(#shadow)"/>
    <circle cx="25" cy="25" r="12" fill="url(#brandGrad)"/>
    <text x="22" y="30" font-family="Inter, sans-serif" font-size="14" fill="#ffffff">🔐</text>
    <text x="45" y="22" font-family="Inter, sans-serif" font-size="12" fill="#1e293b" font-weight="600">端到端加密</text>
    <text x="45" y="38" font-family="Inter, sans-serif" font-size="10" fill="#64748b">AES-256-GCM</text>
  </g>

  <!-- Brand accent -->
  <circle cx="1050" cy="160" r="40" fill="url(#brandGrad)" opacity="0.1" filter="url(#glow)"/>
</svg>
